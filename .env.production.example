# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before deploying
# ─────────────────────────────────────────────────────────────────

# Your server's domain or IP address (no https://, no trailing slash)
# Examples:
#   DOMAIN=myagency.com
#   DOMAIN=192.168.1.100
DOMAIN=yourdomain.com

# Secret key for session signing — use any long random string
SESSION_SECRET=change_this_to_a_long_random_secret_string
